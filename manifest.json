{
  "manifest_version": 3,
  "name": "Интерактивная карта БК",
  "version": "0.1.7",
  "description": "Интерактивная карта подземелий БК с маршрутами, объектами и дропом.",
  "action": {
    "default_title": "Интерактивная карта БК",
    "default_icon": {
      "16": "assets/icons/nav-compass.png",
      "32": "assets/icons/nav-compass.png",
      "48": "assets/icons/nav-compass.png",
      "128": "assets/icons/nav-compass.png"
    }
  },
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://lib.paladins.ru/*",
    "https://*.combats.com/*",
    "http://*.combats.com/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "src/page-bridge.js",
        "data/preload.json",
        "data/maps/*.json",
        "assets/icons/*.png"
      ],
      "matches": [
        "https://*.combats.com/*",
        "http://*.combats.com/*"
      ]
    }
  ]
}
